# ─────────────────────────────────────────────────────────────
# Order Service — Environment Variables
# ─────────────────────────────────────────────────────────────

# Service
SERVICE_NAME=order-service
GRPC_PORT=:50052
METRICS_PORT=:9091
LOG_LEVEL=info

# JWT (public key only — validation)
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TTL=15m

# Rate Limiting
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=50

# Idempotency
IDEMPOTENCY_TTL=24h

# Timeouts
GRPC_SERVER_TIMEOUT=30s
SHUTDOWN_GRACE_PERIOD=30s

# Dependencies
USER_SERVICE_ADDR=localhost:50053

# Database (для Этапа 4)
# DATABASE_URL=postgres://exchange:exchange_pass@localhost:5432/exchange_db?sslmode=disable